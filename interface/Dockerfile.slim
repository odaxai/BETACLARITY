# ==========================================================================
#  BETACLARITY Interface — slim CPU-only image
#  Frontend (React) + Backend (Flask) + ONNX Runtime
#
#  This variant uses the INT8 quantized BetaSR UNet from
#  huggingface.co/OdaxAI/betaclarity-betasr-onnx (quantized with the
#  OdaxAI SDK). It does NOT bundle PyTorch or CUDA, making the image
#  ~5x smaller than the GPU variant and runnable on any x86_64 / arm64
#  Linux machine, including ARM-based laptops and edge devices.
# ==========================================================================

# ---- Stage 1: build the React frontend ----
FROM node:20-alpine AS frontend-build
WORKDIR /build

COPY package.json package-lock.json* ./
RUN npm ci --ignore-scripts 2>/dev/null || npm install

COPY webpack.config.js ./
COPY src/ ./src/
COPY public/ ./public/
COPY components/ ./components/
COPY index.html ./

ENV NODE_ENV=production \
    REACT_APP_API_URL=

RUN npx webpack --mode production


# ---- Stage 2: slim Python runtime + ONNX Runtime ----
FROM python:3.12-slim AS runtime

WORKDIR /app

ENV PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    BETACLARITY_BACKEND=pytorch-cpu \
    BETACLARITY_HF_REPO=OdaxAI/betaclarity-betasr \
    BETACLARITY_HF_FILE=model.pth

RUN apt-get update && apt-get install -y --no-install-recommends \
        libgl1 \
        libglib2.0-0 \
        libgomp1 \
        curl \
        nginx \
    && rm -rf /var/lib/apt/lists/*

COPY backend/requirements.txt /tmp/requirements.txt
# Drop any GPU-specific torch lines from upstream requirements
RUN sed -i '/^torch/d; /^torchvision/d; /^pytorch/d; /^cuda/d; /^opencv-python$/d' /tmp/requirements.txt && \
    pip install --upgrade pip && \
    pip install -r /tmp/requirements.txt && \
    # CPU-only PyTorch wheels (no CUDA, no MKL bloat)
    pip install --index-url https://download.pytorch.org/whl/cpu \
        torch==2.5.* torchvision==0.20.* && \
    # ONNX Runtime + diffusers (UNet inference) + helpers
    pip install \
        onnxruntime==1.20.* \
        diffusers \
        accelerate \
        transformers \
        huggingface-hub \
        gunicorn \
        opencv-python-headless && \
    rm /tmp/requirements.txt && \
    rm -rf /root/.cache/pip /tmp/*

COPY backend/ ./backend/
COPY --from=frontend-build /build/dist /app/static

RUN mkdir -p /app/backend/sessions /app/backend/model

COPY <<'NGINX_CONF' /etc/nginx/sites-available/default
server {
    listen 80;
    server_name _;

    root /app/static;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    # Proxy every non-static request to the Flask backend.
    # Backend routes include: /health, /create_session, /upload_file,
    # /get_preprocessed, /process_distortion, /get_distorted,
    # /apply_denoising, /get_denoised, /compute_metrics, /get_sample_images,
    # /load_sample_image, /chat, /export_measurement, /api/*, ...
    location ~ ^/(api|health|create_session|load_sample|upload_file|get_preprocessed|process_distortion|get_distorted|apply_denoising|get_denoised|compute_metrics|get_sample_images|load_sample_image|enhance|chat|export_measurement|system-info)(/.*)?$ {
        proxy_pass http://127.0.0.1:8001;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_read_timeout 600s;
        proxy_send_timeout 600s;
        client_max_body_size 100M;
    }
}
NGINX_CONF

COPY <<'ENTRYPOINT' /app/entrypoint.sh
#!/bin/bash
set -e

echo "==============================================="
echo "  BETACLARITY Interface (slim/ONNX) starting..."
echo "==============================================="
echo "  Backend: ${BETACLARITY_BACKEND}"
echo "  HF repo: ${BETACLARITY_HF_REPO}"

MODEL_DIR=/app/backend/model
mkdir -p "$MODEL_DIR"
MODEL_PATH="$MODEL_DIR/$BETACLARITY_HF_FILE"

if [ ! -f "$MODEL_PATH" ]; then
    echo "  Downloading $BETACLARITY_HF_FILE from $BETACLARITY_HF_REPO ..."
    python - <<PYDL
import os, sys
from huggingface_hub import hf_hub_download
try:
    p = hf_hub_download(
        repo_id=os.environ["BETACLARITY_HF_REPO"],
        filename=os.environ["BETACLARITY_HF_FILE"],
        local_dir="/app/backend/model",
        token=os.environ.get("HUGGINGFACE_HUB_TOKEN"),
    )
    print(f"  Downloaded to {p}", flush=True)
except Exception as e:
    print(f"  WARNING: model download failed: {e}", file=sys.stderr)
    print("  Backend will start but inference endpoints will fail until model is mounted at $MODEL_PATH", file=sys.stderr)
PYDL
else
    echo "  Model already present at $MODEL_PATH"
fi

echo "  Starting nginx (port 80) and gunicorn (port 8001)..."
echo "==============================================="

nginx

cd /app/backend
exec gunicorn app:app \
    --bind 0.0.0.0:8001 \
    --workers 1 \
    --threads 4 \
    --timeout 600 \
    --access-logfile - \
    --error-logfile -
ENTRYPOINT
RUN chmod +x /app/entrypoint.sh

EXPOSE 80 8001

HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:80/ && curl -f http://localhost:8001/health || exit 1

ENTRYPOINT ["/app/entrypoint.sh"]
